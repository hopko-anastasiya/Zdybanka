<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zdybanka</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var role = ViewData["Role"]?.ToString() ?? "Guest";
        var isAuthenticated = (ViewData["IsAuthenticated"] as bool?) ?? false;
        var returnUrl = Context.Request.Path + Context.Request.QueryString;
    }
    <header class="my-nav-pannel">
        <div class="my-title">
            <div class="my-title-icon">
                <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" fill="#FFFFFF" stroke="#FFFFFF" stroke-width="1.344" transform="rotate(45)">
                    <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                    <g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round" stroke="#CCCCCC" stroke-width="1.536">
                        <defs>
                            <style>
                                .a {
                                    fill: none;
                                    stroke: #FFFFFF;
                                    stroke-linecap: round;
                                    stroke-linejoin: round;
                                }</style>
                        </defs><line class="a" x1="24" y1="31.89" x2="24" y2="16.11"></line><line class="a" x1="16.11" y1="24" x2="31.89" y2="24"></line><path class="a" d="M24,24c-4.84,4.84-8.48,6.88-8.48,11.72a8.53,8.53,0,1,0,17.05,0"></path><path class="a" d="M27.22,43.89a3.88,3.88,0,1,0-6.45,0"></path><path class="a" d="M24,24c4.84-4.84,8.48-6.88,8.48-11.72a8.53,8.53,0,1,0-17,0"></path><path class="a" d="M20.78,4.11a3.88,3.88,0,1,0,6.45,0"></path><path class="a" d="M24,24c-4.84-4.84-6.88-8.48-11.72-8.48a8.53,8.53,0,1,0,0,17.05"></path><path class="a" d="M4.11,27.22a3.88,3.88,0,1,0,0-6.45"></path><path class="a" d="M24,24c4.84,4.84,6.88,8.48,11.72,8.48a8.53,8.53,0,1,0,0-17"></path><path class="a" d="M43.89,20.78a3.88,3.88,0,1,0,0,6.45"></path>
                    </g>
                    <g id="SVGRepo_iconCarrier">
                        <defs>
                            <style>
                                .a {
                                    fill: none;
                                    stroke: #FFFFFF;
                                    stroke-linecap: round;
                                    stroke-linejoin: round;
                                }</style>
                        </defs><line class="a" x1="24" y1="31.89" x2="24" y2="16.11"></line><line class="a" x1="16.11" y1="24" x2="31.89" y2="24"></line><path class="a" d="M24,24c-4.84,4.84-8.48,6.88-8.48,11.72a8.53,8.53,0,1,0,17.05,0"></path><path class="a" d="M27.22,43.89a3.88,3.88,0,1,0-6.45,0"></path><path class="a" d="M24,24c4.84-4.84,8.48-6.88,8.48-11.72a8.53,8.53,0,1,0-17,0"></path><path class="a" d="M20.78,4.11a3.88,3.88,0,1,0,6.45,0"></path><path class="a" d="M24,24c-4.84-4.84-6.88-8.48-11.72-8.48a8.53,8.53,0,1,0,0,17.05"></path><path class="a" d="M4.11,27.22a3.88,3.88,0,1,0,0-6.45"></path><path class="a" d="M24,24c4.84,4.84,6.88,8.48,11.72,8.48a8.53,8.53,0,1,0,0-17"></path><path class="a" d="M43.89,20.78a3.88,3.88,0,1,0,0,6.45"></path>
                    </g>
                </svg>
            </div>
            <div class="my-title-info">
                <h2>Zdybanka</h2>
                <span>Знайди свою подію</span>
            </div>
        </div>
        <div class="auth-controls">
            @if (!isAuthenticated)
            {
                <a class="auth-login-btn" style="background: var(--btn-gradient); color: #ffffff; display: flex; align-items: center; gap: 10px; font-size: 18px; text-decoration: none; padding: 15px 20px; border-radius: 20px; font-weight: 600; box-shadow: 0 4px 6px -1px #0000001a, 0 2px 4px -2px #0000001a;" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl">
                    <span>Увійти</span>
                </a>
            }
        </div>
        <div>
            @if (role == "Admin")
            {
                <partial name="_AdminNav" />
            }
            else if (role == "Organization")
            {
                <partial name="_OrganizationNav" />
            }
            else if (isAuthenticated)
            {
                <partial name="_UserNav" />
            }
        </div>
    </header>
    <div class="container-fluid" padding-bottom="50px">
        <main role="my-main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            &copy; 2026 - Zdybanka - Всі права захищено
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/i18n/uk.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
