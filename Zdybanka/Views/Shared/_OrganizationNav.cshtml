@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var defaultOrganizationId = TemporaryIdentity.CurrentOrganizationId.ToString();
    var organizationIdFromEvents = Context.Request.Query["organizationId"].ToString();
    var organizationIdFromProfile = Context.Request.Query["id"].ToString();
    var currentOrganizationId = !string.IsNullOrWhiteSpace(organizationIdFromEvents)
        ? organizationIdFromEvents
        : (!string.IsNullOrWhiteSpace(organizationIdFromProfile) ? organizationIdFromProfile : defaultOrganizationId);
}
<nav class="my-nav">
    <ul>
        <li class="my-nav-item">
            <a asp-controller="Organizations" asp-action="Profile" asp-route-id="@currentOrganizationId" class="@(currentController == "Organizations" && currentAction == "Profile" ? "active" : "")">
