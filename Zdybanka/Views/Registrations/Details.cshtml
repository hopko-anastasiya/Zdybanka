@model Zdybanka.Models.Registration

@{
    ViewData["Title"] = "Деталі";
}

<h1>Деталі</h1>

<div>
    <h4>Реєстрація</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Registrationdate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Registrationdate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Event)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Event.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.User)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.User.Fullname)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Index">Назад до списку</a>
</div>
