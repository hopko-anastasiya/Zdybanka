@model IEnumerable<Zdybanka.Models.Eventcategory>

@{
    ViewData["Title"] = "Категорії подій";
}

<h1>Категорії подій</h1>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Назва</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Categoryname</td>

            </tr>
        }
    </tbody>
</table>
