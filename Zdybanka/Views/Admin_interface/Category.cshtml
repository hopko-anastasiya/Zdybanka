@model IEnumerable<Zdybanka.Models.Eventcategory>

@{
    ViewData["Title"] = "Категорії";
}

<div class="container">

    @if (TempData["AdminCategorySuccess"] is string successMessage)
    {
        <div id="admin-success-toast" class="admin-toast admin-toast-success" role="status" aria-live="polite">@successMessage</div>
    }

    @if (TempData["AdminCategoryError"] is string errorMessage)
    {
        <div id="admin-error-toast" class="admin-toast admin-toast-error" role="status" aria-live="polite">@errorMessage</div>
    }

    <div class="card category-create-card"style="margin-bottom: 30px;">
        <h3>Нова категорія</h3>
        <form asp-action="CreateCategory" method="post" class="category-create-form">
            @Html.AntiForgeryToken()
            <div class="category-input-wrapper">
                <input type="text" 
                       name="categoryName" 
                       placeholder="Назва категорії..." 
                       class="category-input"
                       maxlength="100"
                       required />
                <button type="submit" class="btn-base btn-confirm">Створити нову категорію</button>
            </div>
        </form>
    </div>

    <div class="categories-grid">
        @if (!Model.Any())
        {
            <p class="categories-empty">Немає категорій. Створіть першу категорію!</p>
        }
        else
        {
            @foreach (var category in Model)
            {
                <div class="card category-item">
                    <h4 class="category-name">@category.Categoryname</h4>
                    <form asp-action="DeleteCategory" 
                          asp-route-id="@category.Id" 
                          method="post" 
                          class="category-delete-form"
                          style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" 
                                class="btn-base category-delete-btn"
                                onclick="return confirm('Видалити категорію «@category.Categoryname»?')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" color="red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash2-icon lucide-trash-2"><path d="M10 11v6"/><path d="M14 11v6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        </button>
                    </form>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const successToast = document.getElementById('admin-success-toast');
            const errorToast = document.getElementById('admin-error-toast');
            
            const hideToast = (toastElement) => {
                if (!toastElement) return;
                
                setTimeout(() => {
                    toastElement.classList.add('is-hiding');
                    toastElement.addEventListener('animationend', () => {
                        toastElement.remove();
                    }, { once: true });
                }, 3200);
            };
            
            hideToast(successToast);
            hideToast(errorToast);
        })();
    </script>
}
