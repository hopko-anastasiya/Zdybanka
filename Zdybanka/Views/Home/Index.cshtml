@{
    ViewData["Title"] = "Головна";
}

<div class="content-wrapper" style="text-align: center; margin-top: 100px; padding: 40px 20px;">
    <div style="margin-bottom: 2rem;">
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.8" transform="rotate(45)" style="width: 80px; height: 80px; stroke: url(#grad1);">
            <defs>
                <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" style="stop-color:#a855f7;stop-opacity:1" />
                    <stop offset="100%" style="stop-color:#ec4899;stop-opacity:1" />
                </linearGradient>
            </defs>
            <path stroke-linecap="round" stroke-linejoin="round" d="M24,24c-4.84,4.84-8.48,6.88-8.48,11.72a8.53,8.53,0,1,0,17.05,0"></path><path stroke-linecap="round" stroke-linejoin="round" d="M27.22,43.89a3.88,3.88,0,1,0-6.45,0"></path><path stroke-linecap="round" stroke-linejoin="round" d="M24,24c4.84-4.84,8.48-6.88,8.48-11.72a8.53,8.53,0,1,0-17,0"></path><path stroke-linecap="round" stroke-linejoin="round" d="M20.78,4.11a3.88,3.88,0,1,0,6.45,0"></path><path stroke-linecap="round" stroke-linejoin="round" d="M24,24c-4.84-4.84-6.88-8.48-11.72-8.48a8.53,8.53,0,1,0,0,17.05"></path><path stroke-linecap="round" stroke-linejoin="round" d="M4.11,27.22a3.88,3.88,0,1,0,0-6.45"></path><path stroke-linecap="round" stroke-linejoin="round" d="M24,24c4.84,4.84,6.88,8.48,11.72,8.48a8.53,8.53,0,1,0,0-17"></path><path stroke-linecap="round" stroke-linejoin="round" d="M43.89,20.78a3.88,3.88,0,1,0,0,6.45"></path>
        </svg>
    </div>
    
    <h1 class="display-3 fw-bold" style="background: var(--btn-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Zdybanka</h1>
    <h3 class="fw-normal mb-4" style="color: var(--label-color);">Відкривайте події вашого міста</h3>
    <p style="margin-bottom: 40px; color: var(--plain-color); font-size: 1.1rem; max-width: 600px; margin-left: auto; margin-right: auto;">
        Знаходьте цікаві заходи, приєднуйтесь до місцевих ком'юніті або створюйте власні події, щоб ділитись досвідом та враженнями з іншими!
    </p>

    <div class="mb-5 d-flex gap-3 justify-content-center flex-wrap">
        <a asp-controller="Account" asp-action="Login" class="btn text-white fw-semibold px-4 py-3" style="background: var(--btn-gradient); border-radius: 30px; font-size: 1.1rem; min-width: 160px; box-shadow: 0 4px 15px rgba(236, 72, 153, 0.4); border: transparent;">Увійти</a>
        <a asp-controller="Account" asp-action="Register" class="btn fw-semibold px-4 py-3" style="background: var(--card-color); border: 2px solid var(--btn-border-color); color: var(--text-color); border-radius: 30px; font-size: 1.1rem; min-width: 160px;">Реєстрація</a>
    </div>

    <div>
        <a asp-controller="Events" asp-action="Index" class="text-decoration-none fw-medium" style="color: #a855f7; display: inline-flex; align-items: center; gap: 8px;">
            <span>Переглянути події без авторизації</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
    </div>
</div>

