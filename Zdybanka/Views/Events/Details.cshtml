@model Zdybanka.Models.Event

@{
    ViewData["Title"] = "Деталі";
    var suggestedEvents = ViewData["SuggestedEvents"] as List<Zdybanka.Models.Event> ?? new List<Zdybanka.Models.Event>();
    var suggestedRegistrationCounts = ViewData["SuggestedRegistrationCounts"] as Dictionary<int, int> ?? new Dictionary<int, int>();
    var suggestedFavoriteCounts = ViewData["SuggestedFavoriteCounts"] as Dictionary<int, int> ?? new Dictionary<int, int>();

    var isAuthenticated = (ViewData["IsAuthenticated"] as bool?) ?? false;
    var suggestedFavoriteEventIds = (ViewData["SuggestedFavoriteEventIds"] as List<int> ?? new List<int>()).ToHashSet();
    var isRegistered = (ViewData["IsRegistered"] as bool?) ?? false;
    var isFavorited = (ViewData["IsFavorited"] as bool?) ?? false;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<section class="event-details-page">
    <div class="event-details-back-wrap">
        <a asp-action="Index" class="btn-base event-details-back-btn">Назад до списку</a>
    </div>

    <article class="card event-details-card">
        <div class="event-details-media">
            <span class="event-details-category-badge">@(Model.Category?.Categoryname ?? "Без категорії")</span>
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="Зображення події @Model.Title" class="event-details-image" />
            }
            else
            {
                <div class="event-details-image-placeholder" aria-label="Немає фото">
                    Немає фото
                </div>
            }
        </div>

        <div class="event-details-content">
            <h1 class="event-details-title">@Model.Title</h1>

            <p class="event-details-description">
                @(string.IsNullOrWhiteSpace(Model.Description) ? "Опис відсутній." : Model.Description)
            </p>

            <div class="event-details-meta-list">
                <div class="event-details-meta-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="event-details-meta-icon lucide lucide-calendar-icon lucide-calendar"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                    <div>
                        <span class="event-details-label">Дата та час</span>
                        <p>@(Model.Eventdate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</p>
                    </div>
                </div>

                <div class="event-details-meta-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="event-details-meta-icon lucide lucide-map-pin-icon lucide-map-pin"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                    <div>
                        <span class="event-details-label">Місце</span>
                        <p>@(string.IsNullOrWhiteSpace(Model.Location) ? "-" : Model.Location)</p>
                    </div>
                </div>

                <div class="event-details-meta-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="event-details-meta-icon lucide lucide-building2-icon lucide-building-2"><path d="M10 12h4"/><path d="M10 8h4"/><path d="M14 21v-3a2 2 0 0 0-4 0v3"/><path d="M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2"/><path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"/></svg>
                    <div>
                        <span class="event-details-label">Організація</span>
                        <p>@(Model.Organization?.Fullname ?? "-")</p>
                    </div>
                </div>
            </div>

            @if (isAuthenticated)
            {
                <div class="event-details-actions mt-4 d-flex gap-3 align-items-center">
                    @if (isRegistered)
                    {
                        <div class="btn-base" style="background-color: #10b981; color: white; cursor: default; border: none; font-weight: 600;">
                            Ви зареєстровані на цю подію
                        </div>
                    }
                    else
                    {
                        <form asp-controller="Registrations" asp-action="Toggle" method="post" class="guest-registration-form" style="margin: 0;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="eventId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="btn-base guest-registration-btn">
                                Зареєструватись
                            </button>
                        </form>
                    }

                    <form asp-controller="Userfavorites" asp-action="Toggle" method="post" class="guest-favorite-form" style="margin: 0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="eventId" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" style="position: static; width: auto; height: auto; border-radius: 8px; padding: 8px 16px; display:flex; align-items:center; gap: 8px;" class="guest-favorite-btn btn btn-outline-secondary @(isFavorited ? "is-favorited" : string.Empty)" aria-label="@(isFavorited ? "Прибрати з уподобаних" : "Уподобати")" aria-pressed="@(isFavorited.ToString().ToLowerInvariant())">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="guest-favorite-icon guest-favorite-icon-outline lucide lucide-heart" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="guest-favorite-icon guest-favorite-icon-filled lucide lucide-heart" aria-hidden="true" style="color: #e74c3c;"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg>
                            <span class="favorite-text">@(isFavorited ? "В уподобаних" : "Уподобати")</span>
                        </button>
                    </form>
                </div>
            }
        </div>
    </article>

    <section class="event-details-suggested">
        <h3>Події що також можуть вас зацікавити</h3>

        @if (!suggestedEvents.Any())
        {
            <p class="event-details-suggested-empty">Інших подій цієї категорії поки немає.</p>
        }
        else
        {
            <div class="guest-events-grid">
                @foreach (var item in suggestedEvents)
                {
                    var categoryName = item.Category?.Categoryname ?? "Без категорії";
                    var registrationsCount = suggestedRegistrationCounts.TryGetValue(item.Id, out var regCount) ? regCount : 0;
                    var favoritesCount = suggestedFavoriteCounts.TryGetValue(item.Id, out var favCount) ? favCount : 0;

                <div class="guest-card-shell guest-list-event-card">
                    <a asp-action="Details" asp-route-id="@item.Id" class="guest-event-card event-details-suggested-card">
                        <div class="guest-event-image-wrap">
                            <span class="guest-event-category-badge">@categoryName</span>
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="Зображення @item.Title" class="guest-event-image" />
                            }
                            else
                            {
                                <div class="guest-event-image guest-event-image-placeholder">Немає фото</div>
                            }
                        </div>
                        <div class="guest-event-content">
                            <h5>@item.Title</h5>
                            <p>@item.Eventdate?.ToString("dd.MM.yyyy HH:mm")</p>
                            <p>@item.Location</p>
                            <div class="guest-event-stats">
                                <span class="guest-event-stat-item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart-icon lucide-heart"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>
                                    @favoritesCount
                                </span>
                                <span class="guest-event-stat-item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users-icon lucide-users"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><circle cx="9" cy="7" r="4"/></svg>
                                    @registrationsCount
                                </span>
                            </div>
                        </div>
                    </a>

                    @if (isAuthenticated)
                    {
                        <form asp-controller="Userfavorites" asp-action="Toggle" method="post" class="guest-favorite-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="eventId" value="@item.Id" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="guest-favorite-btn @(suggestedFavoriteEventIds.Contains(item.Id) ? "is-favorited" : string.Empty)" aria-label="@(suggestedFavoriteEventIds.Contains(item.Id) ? "Прибрати з уподобаних" : "Уподобати")" aria-pressed="@(suggestedFavoriteEventIds.Contains(item.Id).ToString().ToLowerInvariant())">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="guest-favorite-icon guest-favorite-icon-outline lucide lucide-heart" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg>
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="guest-favorite-icon guest-favorite-icon-filled lucide lucide-heart" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg>
                            </button>
                        </form>
                    }
                </div>
                }
            </div>
        }
    </section>
</section>

@section Scripts {
    <script>
        (function () {
            // Favorite Button Handling
            const favoriteForms = Array.from(document.querySelectorAll('.guest-favorite-form'));

            function updateFavoriteButton(button, isFavorited, isMainCard) {
                button.classList.toggle('is-favorited', isFavorited);
                button.setAttribute('aria-pressed', isFavorited ? 'true' : 'false');
                button.setAttribute('aria-label', isFavorited ? 'Прибрати з уподобаних' : 'Уподобати');
                
                if (isMainCard) {
                    const textSpan = button.querySelector('.favorite-text');
                    if (textSpan) {
                        textSpan.textContent = isFavorited ? 'В уподобаних' : 'Уподобати';
                    }
                }
            }

            favoriteForms.forEach((form) => {
                form.addEventListener('submit', async (event) => {
                    event.preventDefault();

                    const button = form.querySelector('.guest-favorite-btn');
                    if (!button || button.dataset.isSubmitting === 'true') {
                        return;
                    }

                    button.dataset.isSubmitting = 'true';
                    button.disabled = true;

                    try {
                        const response = await fetch(form.action, {
                            method: 'POST',
                            body: new FormData(form),
                            credentials: 'same-origin',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        if (!response.ok) {
                            throw new Error('Favorite toggle request failed.');
                        }

                        const isNowFavorited = !button.classList.contains('is-favorited');
                        const isMainCard = button.classList.contains('btn'); // Hack to detect main event action btn
                        updateFavoriteButton(button, isNowFavorited, isMainCard);
                    } catch (error) {
                        console.error(error);
                    } finally {
                        button.disabled = false;
                        button.dataset.isSubmitting = 'false';
                    }
                });
            });

            // Registration Button Handling
            const regForms = Array.from(document.querySelectorAll('.guest-registration-form'));
            
            regForms.forEach((form) => {
                form.addEventListener('submit', async (event) => {
                    event.preventDefault();

                    const button = form.querySelector('.guest-registration-btn');
                    if (!button || button.dataset.isSubmitting === 'true') {
                        return;
                    }

                    button.dataset.isSubmitting = 'true';
                    button.disabled = true;
                    const originalText = button.textContent;
                    button.textContent = "Обробка...";

                    try {
                        const response = await fetch(form.action, {
                            method: 'POST',
                            body: new FormData(form),
                            credentials: 'same-origin',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        if (!response.ok) {
                            throw new Error('Registration toggle request failed.');
                        }

                        // Success! Since UX specifies "show green pill instead of button when registered",
                        // we can replace the button+form with the success pill dynamically, or just reload.
                        // Refreshing will get the proper verified pill from the server.
                        location.reload();

                    } catch (error) {
                        console.error(error);
                        button.textContent = originalText;
                        button.disabled = false;
                        button.dataset.isSubmitting = 'false';
                    }
                });
            });
        })();
    </script>
}
