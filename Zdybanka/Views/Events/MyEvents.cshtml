@model Zdybanka.Models.ViewModels.OrganizationEventsViewModel

@{
    ViewData["Title"] = "Мої події";
    var organization = Model.Organization;
    var canCreateEvent = Model.CanCreateEvent;
    var shouldOpenCreateOverlay = (ViewData["OpenCreateOverlay"] as bool?) == true;
    var shouldOpenCreateImportOverlay = (ViewData["OpenCreateImportOverlay"] as bool?) == true;
    var eventImportResult = ViewData["EventImportResult"] as Zdybanka.Models.ViewModels.EventImportResultViewModel;
}

<div class="container">
    <div class="page-first-row">
        <div class="page-info">
            <h2>Мої події</h2>
            <span>Керуйте подіями вашої організації</span>
        </div>

        @if (organization != null)
        {
            if (canCreateEvent)
            {
                <button type="button" class="btn-base btn-confirm" id="open-create-event-dialog">Додати подію</button>
            }
            else
            {
                var isBlockedOrganization = organization.Status?.Statusname == "Заблокована";
                var isPendingVerification = organization.Status?.Statusname == "Очікує підтвердження";
                var isPendingUnblock = organization.Status?.Statusname == "Очікує розблокування";
                var requestActionLabel = isPendingUnblock
                    ? "Заявка на розблокування подана"
                    : isPendingVerification
                        ? "Заявка на верифікацію подана"
                        : isBlockedOrganization
                            ? "Подати заявку на розблокування"
                            : "Подати заявку на верифікацію";

                if (isPendingVerification || isPendingUnblock)
                {
                    <button type="button" class="btn-base" disabled>@requestActionLabel</button>
                }
                else
                {
                    <form asp-action="SubmitOrganizationStatusRequest" asp-route-organizationId="@organization.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-base btn-confirm">@requestActionLabel</button>
                    </form>
                }
            }
        }
    </div>

    @if (organization == null)
{
    <p>Організацію не знайдено.</p>
}
else
{
    if (!canCreateEvent)
    {
        <p class="events-feedback">Заблоковані або не верифіковані організації не можуть додавати нові події.</p>
    }

    if (!Model.Events.Any())
    {
        <p class="events-feedback">Подій для цієї організації ще немає.</p>
    }
    else
    {
        <div class="organizations-search-form my-events-search-form">
            <input type="text"
                   id="my-events-search-input"
                   class="organizations-search-input"
                   placeholder="Пошук за назвою події" />
        </div>

        <div class="org-events-list">
            @{
                var openEditId = ViewData["OpenEditOverlayForEventId"] as int?;
            }
            @foreach (var item in Model.Events)
            {
                var registrationsCount = Model.RegistrationCountsByEventId.TryGetValue(item.Id, out var count)
                    ? count
                    : 0;

                <div class="org-event card my-event-item" data-event-title="@item.Title">
                    <div class="org-event-media">
                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="Зображення події @item.Title" class="org-event-image" />
                        }
                        else
                        {
                            <div class="org-event-image-placeholder" aria-label="Немає фото">Немає фото</div>
                        }
                    </div>

                    <div class="org-event-content">
                        <div class="org-event-status-category">
                            <div class="org-event-title-wrap">
                                <h4 class="main-info">@item.Title</h4>
                                @{
                                    var statusClass = "status-badge status-default";
                                    if (item.Status?.Statusname == "Запланована")
                                        statusClass = "status-badge status-planned";
                                    else if (item.Status?.Statusname == "Відмінена")
                                        statusClass = "status-badge status-cancelled";
                                    else if (item.Status?.Statusname == "Проведена")
                                        statusClass = "status-badge status-completed";
                                }
                                <div class="org-event-meta-badges">
                                    <span class="@statusClass">@item.Status?.Statusname</span>
                                    <span class="status-badge">@item.Category?.Categoryname</span>
                                </div>
                            </div>

                            <div class="event-actions">
                                <button type="button" class="btn-base btn-edit" onclick="document.getElementById('edit-event-dialog-@item.Id').showModal()">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pencil-icon lucide-pencil"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg>
                                </button>
                                <form asp-action="DeleteMyEvent" asp-route-id="@item.Id" asp-route-organizationId="@organization!.Id" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-base btn-decline" onclick="return confirm('Видалити подію «@item.Title»?')">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" color="red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash2-icon lucide-trash-2"><path d="M10 11v6"/><path d="M14 11v6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="org-event-details">
                            <span>
                                @item.Description
                            </span>
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin-icon lucide-map-pin"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                                @item.Location
                            </span>
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-icon lucide-calendar"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
                                @item.Eventdate
                            </span>
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users-icon lucide-users"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><circle cx="9" cy="7" r="4"/></svg>
                                @registrationsCount реєстрацій
                            </span>
                        </div>

                        <div>
                            <form asp-action="ExportRegistrations" asp-route-id="@item.Id" method="get">
                                <button type="submit" class="btn-base">Вивантажити список реєстрацій</button>
                            </form>
                        </div>
                    </div>
                </div>

                <dialog id="edit-event-dialog-@item.Id">
                    <form asp-action="EditMyEvent" asp-route-organizationId="@organization!.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@item.Id" />
                        <h3>Редагувати подію</h3>

                        <div class="new-event-form">
                            <div asp-validation-summary="All" class="text-danger"></div>
                            <div class="form-group">
                                <label class="control-label">Назва</label>
                                <input type="text" name="Title" value="@item.Title" class="form-control" />
                            </div>
                            <div class="form-group">
                                <label class="control-label">Опис</label>
                                <textarea name="Description" class="form-control" required>@item.Description</textarea>
                            </div>
                            <div class="form-group">
                                <label class="control-label">Дата та час події</label>
                                <input type="datetime-local" name="Eventdate" value="@item.Eventdate?.ToString("yyyy-MM-ddTHH:mm")" class="form-control" />
                            </div>
                            <div class="form-group">
                                <label class="control-label">Місце проведення</label>
                                <input type="text" name="Location" value="@item.Location" class="form-control" required />
                            </div>
                            <div class="form-group">
                                <label class="control-label">Посилання на зображення</label>
                                <input type="text" name="ImageUrl" value="@item.ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                            </div>
                            <div class="form-group">
                                <label class="control-label">Категорія</label>
                                <select name="Categoryid" class="form-control">
                                    @foreach (var cat in Model.Categories)
                                    {
                                        if (cat.Value == item.Categoryid?.ToString())
                                        {
                                            <option value="@cat.Value" selected="selected">@cat.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@cat.Value">@cat.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="control-label">Статус</label>
                                <select name="Statusid" class="form-control">
                                    @if (!Model.Statuses.Any(st => st.Value == item.Statusid?.ToString()) && item.Statusid.HasValue && item.Status != null)
                                    {
                                        <option value="@item.Statusid" selected="selected">@item.Status.Statusname</option>
                                    }

                                    @foreach (var st in Model.Statuses)
                                    {
                                        if (st.Value == item.Statusid?.ToString())
                                        {
                                            <option value="@st.Value" selected="selected">@st.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@st.Value">@st.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="form-action">
                            <button type="submit" class="btn-base btn-confirm">Зберегти</button>
                            <button type="button" class="btn-base btn-decline" onclick="document.getElementById('edit-event-dialog-@item.Id').close()">Скасувати</button>
                        </div>
                    </form>
                </dialog>
            }
        </div>

        <p id="my-events-empty" class="organization-search-empty" style="display:none;">Нічого не знайдено за вашим запитом.</p>
    }

    if (canCreateEvent)
    {
        <dialog id="create-event-dialog" class="create-event-dialog">
            <form asp-action="CreateMyEvent" asp-route-organizationId="@organization.Id" method="post" id="create-event-form">
                @Html.AntiForgeryToken()
                <button type="button" class="create-event-overlay-toggle" id="toggle-create-event-import" aria-pressed="false" aria-label="Перейти до імпорту" title="Перейти до імпорту">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right-icon lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
                </button>
                <h3>Створити нову подію</h3>

                <div class="new-event-form create-event-panel" id="create-event-panel-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group">
                        <label asp-for="NewEvent.Title" class="control-label"></label>
                        <input asp-for="NewEvent.Title" class="form-control" />
                        <span asp-validation-for="NewEvent.Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="NewEvent.Description" class="control-label"></label>
                        <textarea asp-for="NewEvent.Description" class="form-control" required></textarea>
                        <span asp-validation-for="NewEvent.Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="NewEvent.Eventdate" class="control-label"></label>
                        <input asp-for="NewEvent.Eventdate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="NewEvent.Eventdate" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="NewEvent.Location" class="control-label"></label>
                        <input asp-for="NewEvent.Location" class="form-control" required />
                        <span asp-validation-for="NewEvent.Location" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="NewEvent.ImageUrl" class="control-label"></label>
                        <input asp-for="NewEvent.ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                        <span asp-validation-for="NewEvent.ImageUrl" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="NewEvent.Categoryid" class="control-label"></label>
                        <select asp-for="NewEvent.Categoryid" class="form-control" asp-items="Model.Categories"></select>
                        <span asp-validation-for="NewEvent.Categoryid" class="text-danger"></span>
                    </div>
                </div>

                <div class="create-event-panel create-event-panel-import" id="create-event-panel-import" hidden>
                    <div class="organization-import-controls create-event-import-controls">
                        <div class="organization-import-file-picker">
                            <input style="position: relative;z-index: 2;"
                                type="file"
                                name="csvFile"
                                id="create-event-import-file"
                                class="organization-import-file-input"
                                accept=".csv,text/csv"
                                required />
                            <label for="create-event-import-file" class="btn-base organization-import-file-btn" aria-label="Обрати файл">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder-up-icon lucide-folder-up"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/><path d="M12 10v6"/><path d="m9 13 3-3 3 3"/></svg>
                            </label>
                                     <span id="create-event-import-file-name" class="organization-import-file-name">Файл не обрано</span>
                        </div>
                        <div class="organization-import-actions">
                            <button type="submit"
                                    class="btn-base btn-confirm"
                                    id="create-event-import-run"
                                    formaction="@Url.Action("ImportMyEvents", "Events", new { organizationId = organization.Id })"
                                    formmethod="post"
                                    formenctype="multipart/form-data">Імпортувати</button>
                            <button type="button" id="create-event-import-clear" class="btn-base organization-import-clear-btn">Очистити</button>
                        </div>
                    </div>

                    <div class="organization-import-results" id="create-event-import-results">
                        @if (eventImportResult is not null)
                        {
                            <div class="admin-feedback @(eventImportResult.SkippedCount == 0 ? "admin-feedback-success" : "admin-feedback-error") organization-import-summary">
                                @eventImportResult.Summary
                            </div>

                            @if (eventImportResult.Messages.Any())
                            {
                                <ul class="organization-import-messages">
                                    @foreach (var message in eventImportResult.Messages)
                                    {
                                        <li class="organization-import-message organization-import-message-error">
                                            @if (message.RowNumber > 0)
                                            {
                                                <strong>Рядок @message.RowNumber:</strong>
                                            }
                                            @message.Message
                                        </li>
                                    }
                                </ul>
                            }
                        }
                        else
                        {
                            <p class="organization-import-empty">Після завантаження файлу тут з'явиться звіт про імпорт.</p>
                        }
                    </div>
                </div>

                <div class="form-action">
                    <button type="submit" class="btn-base btn-confirm" id="save-event-btn">Створити подію</button>
                    <button type="button" id="close-create-event-dialog" class="btn-base btn-decline">Скасувати</button>
                </div>
            </form>
        </dialog>
    }
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const dialog = document.getElementById('create-event-dialog');
            const createEventForm = document.getElementById('create-event-form');
            const openButton = document.getElementById('open-create-event-dialog');
            const closeButton = document.getElementById('close-create-event-dialog');
            const saveButton = document.getElementById('save-event-btn');
            const toggleImportOverlayButton = document.getElementById('toggle-create-event-import');
            const createPanelForm = document.getElementById('create-event-panel-form');
            const createPanelImport = document.getElementById('create-event-panel-import');
            const importFileInput = document.getElementById('create-event-import-file');
            const importFileName = document.getElementById('create-event-import-file-name');
            const importClearButton = document.getElementById('create-event-import-clear');
            const importResults = document.getElementById('create-event-import-results');
            const createDateInput = dialog ? dialog.querySelector('input[name="NewEvent.Eventdate"]') : null;
            const shouldOpenCreateOverlay = @((canCreateEvent && shouldOpenCreateOverlay).ToString().ToLowerInvariant());
            const shouldOpenCreateImportOverlay = @((canCreateEvent && shouldOpenCreateOverlay && shouldOpenCreateImportOverlay).ToString().ToLowerInvariant());

            const defaultImportMessage = '<p class="organization-import-empty">Після завантаження файлу тут з\'явиться звіт про імпорт.</p>';

            const applyMinDate = function (dateInput) {
                if (!dateInput) {
                    return;
                }

                const minDate = new Date(Date.now() - 60 * 60 * 1000);
                const pad = function (n) { return String(n).padStart(2, '0'); };
                const minStr = minDate.getFullYear() + '-' + pad(minDate.getMonth() + 1) + '-' + pad(minDate.getDate())
                    + 'T' + pad(minDate.getHours()) + ':' + pad(minDate.getMinutes());
                dateInput.min = minStr;
            };

            const resetImportInterface = function () {
                if (importFileInput) {
                    importFileInput.value = '';
                }
                if (importFileName) {
                    importFileName.textContent = 'Файл не обрано';
                }
                if (importResults) {
                    importResults.innerHTML = defaultImportMessage;
                }
            };

            const clearCreateFormValues = function () {
                if (!createEventForm) {
                    return;
                }

                createEventForm.querySelectorAll('input[type="text"], input[type="datetime-local"], textarea').forEach(function (field) {
                    field.value = '';
                });

                createEventForm.querySelectorAll('select').forEach(function (field) {
                    field.selectedIndex = 0;
                });

                createEventForm.querySelectorAll('.field-validation-error, .field-validation-valid, .text-danger').forEach(function (field) {
                    if (field.hasAttribute('asp-validation-summary') || field.getAttribute('data-valmsg-summary') === 'true') {
                        field.innerHTML = '';
                    } else {
                        field.textContent = '';
                    }
                });

                createEventForm.querySelectorAll('.input-validation-error').forEach(function (field) {
                    field.classList.remove('input-validation-error');
                });

                applyMinDate(createDateInput);
            };

            const setImportMode = function (enabled) {
                if (!dialog || !createPanelForm || !createPanelImport || !toggleImportOverlayButton) {
                    return;
                }

                dialog.classList.toggle('is-import-mode', enabled);
                createPanelForm.hidden = enabled;
                createPanelImport.hidden = !enabled;
                toggleImportOverlayButton.classList.toggle('is-back', enabled);
                toggleImportOverlayButton.setAttribute('aria-label', enabled ? 'Повернутися до форми події' : 'Перейти до імпорту');
                toggleImportOverlayButton.setAttribute('title', enabled ? 'Повернутися до форми події' : 'Перейти до імпорту');
                toggleImportOverlayButton.setAttribute('aria-pressed', enabled ? 'true' : 'false');

                createPanelForm.querySelectorAll('input, select, textarea').forEach(function (field) {
                    field.disabled = enabled;
                });

                if (saveButton) {
                    saveButton.disabled = enabled;
                }

                if (enabled) {
                    clearCreateFormValues();
                }
            };

            if (toggleImportOverlayButton && dialog) {
                toggleImportOverlayButton.addEventListener('click', function () {
                    const isImportMode = dialog.classList.contains('is-import-mode');
                    setImportMode(!isImportMode);
                });
            }

            if (importFileInput && importFileName) {
                importFileInput.addEventListener('change', function () {
                    importFileName.textContent = importFileInput.files && importFileInput.files.length
                        ? importFileInput.files[0].name
                        : 'Файл не обрано';
                });
            }

            if (importClearButton) {
                importClearButton.addEventListener('click', function () {
                    resetImportInterface();
                });
            }

            if (openButton && dialog && typeof dialog.showModal === 'function') {
                openButton.addEventListener('click', function () {
                    applyMinDate(createDateInput);
                    setImportMode(false);
                    clearCreateFormValues();
                    resetImportInterface();
                    dialog.showModal();
                });
            }

            if (closeButton && dialog) {
                closeButton.addEventListener('click', function () {
                    setImportMode(false);
                    clearCreateFormValues();
                    resetImportInterface();
                    dialog.close();
                });
            }

            if (dialog) {
                dialog.addEventListener('close', function () {
                    setImportMode(false);
                    clearCreateFormValues();
                    resetImportInterface();
                });
            }

            if (shouldOpenCreateOverlay && dialog && typeof dialog.showModal === 'function') {
                applyMinDate(createDateInput);
                setImportMode(shouldOpenCreateImportOverlay);
                if (!shouldOpenCreateImportOverlay) {
                    resetImportInterface();
                }
                dialog.showModal();
            }

            @if (ViewData["OpenEditOverlayForEventId"] is int editId)
            {
                <text>
                const editDialog = document.getElementById('edit-event-dialog-@editId');
                if (editDialog && typeof editDialog.showModal === 'function') {
                    editDialog.showModal();
                }
                </text>
            }

            (() => {
                const searchInput = document.getElementById('my-events-search-input');
                const items = Array.from(document.querySelectorAll('.my-event-item'));
                const emptyMessage = document.getElementById('my-events-empty');

                if (!searchInput || !items.length) {
                    return;
                }

                const normalize = (value) => (value || '').trim().toLowerCase();

                const filterItems = () => {
                    const query = normalize(searchInput.value);
                    let visibleCount = 0;

                    items.forEach((item) => {
                        const title = normalize(item.getAttribute('data-event-title'));
                        const isVisible = !query || title.includes(query);

                        item.style.display = isVisible ? '' : 'none';
                        if (isVisible) {
                            visibleCount += 1;
                        }
                    });

                    if (emptyMessage) {
                        emptyMessage.style.display = visibleCount === 0 ? 'block' : 'none';
                    }
                };

                searchInput.addEventListener('input', filterItems);
                filterItems();
            })();
        })();
    </script>
}

<script>
    document.querySelectorAll('[id^="edit-event-dialog-"]').forEach(function (editDialog) {
        var dateInput = editDialog.querySelector('input[type="datetime-local"]');
        if (!dateInput) return;

        editDialog.addEventListener('toggle', function () {
            if (editDialog.open) {
                var minDate = new Date(Date.now() - 60 * 60 * 1000);
                var pad = function (n) { return String(n).padStart(2, '0'); };
                var minStr = minDate.getFullYear() + '-' + pad(minDate.getMonth() + 1) + '-' + pad(minDate.getDate())
                    + 'T' + pad(minDate.getHours()) + ':' + pad(minDate.getMinutes());
                dateInput.min = minStr;
            }
        });
    });
</script>

</div>

