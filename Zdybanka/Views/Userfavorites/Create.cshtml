@model Zdybanka.Models.Userfavorite

@{
    ViewData["Title"] = "Створити";
}

<h1>Створити</h1>

<h4>Улюблена подія</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Userid" class="control-label"></label>
                <select asp-for="Userid" class="form-control select2-search" asp-items="ViewBag.Userid"></select>
            </div>
            <div class="form-group">
                <label asp-for="Eventid" class="control-label"></label>
                <select asp-for="Eventid" class="form-control select2-search" asp-items="ViewBag.Eventid"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Створити" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Назад до списку</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
