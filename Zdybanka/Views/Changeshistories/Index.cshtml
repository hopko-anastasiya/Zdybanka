@model IEnumerable<Zdybanka.Models.Changeshistory>
@using Zdybanka.Controllers

@{
    ViewData["Title"] = "Історія змін";
}

<h1>Історія змін</h1>

<p>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Змінені поля</th>
            <th>
                @Html.DisplayNameFor(model => model.Changedat)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Event)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        var changes = ChangeshistoriesController.ParseChanges(item.Changedata);
        <tr>
            <td>
                @if (changes.Any())
                {
                    foreach (var c in changes)
                    {
                        <div><strong>@c.Field:</strong> «@c.OldValue» → «@c.NewValue»</div>
                    }
                }
                else
                {
                    <em>Немає даних</em>
                }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Changedat)
            </td>
            <td>
                @item.Event?.Title
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Деталі</a>
            </td>
        </tr>
}
    </tbody>
</table>
