@model Zdybanka.Models.Changeshistory
@using Zdybanka.Controllers

@{
    ViewData["Title"] = "Деталі";
    var changes = ChangeshistoriesController.ParseChanges(Model.Changedata);
}

<h1>Деталі</h1>

<div>
    <h4>Зміна</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Змінені поля</dt>
        <dd class="col-sm-10">
            @if (changes.Any())
            {
                foreach (var c in changes)
                {
                    <div><strong>@c.Field:</strong> «@c.OldValue» → «@c.NewValue»</div>
                }
            }
            else
            {
                <em>Немає даних</em>
            }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Changedat)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Changedat)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Event)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Event.Title)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Index">Назад до списку</a>
</div>
