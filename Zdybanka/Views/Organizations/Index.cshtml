@model IEnumerable<Zdybanka.Models.Organization>

@{
    ViewData["Title"] = "Організації";
}

<div class="d-flex align-items-center mb-3">
    <h1 class="mb-0">Організації</h1>
    <a asp-action="Create" class="btn btn-primary ms-3" title="Створити нову">+</a>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Fullname)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Createdat)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Fullname)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Createdat)
            </td>
            <td>
                @{
                    var statusClass = item.Status.Statusname == "Верифікована" ? "status-planned" :
                                      item.Status.Statusname == "Не верифікована" ? "status-default" :
                                      item.Status.Statusname == "Заблокована" ? "status-cancelled" : "status-default";
                }
                <span class="status-badge @statusClass">@item.Status.Statusname</span>
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Редагувати</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Деталі</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Видалити</a>
            </td>
        </tr>
}
    </tbody>
</table>
