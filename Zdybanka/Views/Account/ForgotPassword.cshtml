@model Zdybanka.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Забули пароль?";
    ViewData["Subtitle"] = "Введіть свою електронну пошту, і ми надішлемо вам посилання для відновлення пароля.";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<form asp-action="ForgotPassword" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
    <div class="form-group mb-4">
        <label asp-for="Email" class="control-label fw-semibold mb-1" style="color: var(--label-color)"></label>
        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>
    <div class="form-group text-center">
        <button type="submit" class="w-100 auth-btn">Відправити посилання</button>
    </div>
    <div class="text-center mt-4">
        <p class="text-muted small mb-0">
            <a asp-action="Login" class="text-decoration-none text-muted" style="opacity: 0.7;">&larr; Повернутись до входу</a>
        </p>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
