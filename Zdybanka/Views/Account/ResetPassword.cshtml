@model Zdybanka.Models.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Скидання пароля";
    ViewData["Subtitle"] = "Будь ласка, введіть ваш новий пароль.";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<form asp-action="ResetPassword" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
    <input type="hidden" asp-for="Email" />
    <input type="hidden" asp-for="Token" />

    <div class="form-group mb-3">
        <label asp-for="Password" class="control-label fw-semibold mb-1" style="color: var(--label-color)"></label>
        <input asp-for="Password" class="form-control" placeholder="Новий пароль" type="password" />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>
    
    <div class="form-group mb-4">
        <label asp-for="ConfirmPassword" class="control-label fw-semibold mb-1" style="color: var(--label-color)"></label>
        <input asp-for="ConfirmPassword" class="form-control" placeholder="Підтвердіть новий пароль" type="password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>

    <div class="form-group text-center">
        <button type="submit" class="w-100 auth-btn">Змінити пароль</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
